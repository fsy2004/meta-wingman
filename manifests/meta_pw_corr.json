{
  "id": "meta_pw_corr",
  "title": "相关系数合并",
  "title_en": "Correlation meta-analysis",
  "category": "meta",
  "family": "Meta 分析",
  "language": "R",
  "library": "launcher",
  "interp": "Rscript",
  "status": "turnkey",
  "tier": "T1",
  "entry": "adapters/meta/run_pairwise.R",
  "workdir": "adapters/meta",
  "description": "相关系数 meta 分析:在 Fisher z 尺度合并各研究相关系数并回变换为 r,输出森林图与汇总表。基于 meta::metacor。",
  "inputs": [
    {
      "name": "input",
      "flag": "--input",
      "label": "相关系数 CSV",
      "format": "csv",
      "required": true,
      "primary": true,
      "mem_axis": "n_rows",
      "example": "example_data/correlation.csv",
      "spec": "相关系数:每行一个研究,需列 cor(相关系数 r)、n(样本量)+ 研究名列(默认 study)。合并在 Fisher z 尺度进行,结果回变换为 r。"
    }
  ],
  "params_schema": {
    "type": "object",
    "properties": {
      "method": {
        "type": "string",
        "title": "τ² 估计方法",
        "default": "REML",
        "enum": [
          "REML",
          "DL",
          "PM",
          "SJ",
          "EB",
          "ML",
          "HE"
        ]
      },
      "knha": {
        "type": "boolean",
        "title": "Knapp-Hartung 校正(推荐)",
        "default": true
      },
      "slab": {
        "type": "string",
        "title": "研究名列名",
        "default": "study"
      }
    }
  },
  "param_flags": {
    "method": "--method",
    "knha": "--knha",
    "slab": "--slab"
  },
  "outputs": [
    {
      "glob": "*.png",
      "display": "image"
    },
    {
      "glob": "*.csv",
      "display": "table"
    }
  ],
  "mem_hint": {
    "model": "linear",
    "killer_dim": "研究数",
    "matrix_copies": 3,
    "calibrated": true,
    "note": "Meta 分析为研究级汇总数据(通常几十行),内存开销极小,基本恒为绿灯。"
  },
  "group": "synthesis",
  "item_order": 70,
  "analysis": "corr",
  "shape": "correlation"
}