{
  "id": "meta_dta_lr_dor",
  "title": "似然比 · 诊断比值比(LR / DOR)",
  "title_en": "Likelihood ratios / diagnostic OR",
  "category": "meta",
  "family": "诊断准确性 Diagnostic Test Accuracy",
  "language": "R",
  "library": "launcher",
  "interp": "Rscript",
  "status": "turnkey",
  "tier": "T1",
  "entry": "adapters/meta/run_diagnostic.R",
  "workdir": "adapters/meta",
  "description": "各研究诊断比值比(DOR)的森林图(对数刻度,含 95% 置信区间)与双变量模型合并操作点,并输出合并阳性似然比(+LR)、阴性似然比(-LR)与诊断比值比及其区间汇总表。基于 mada::madad / mada::SummaryPts,由 meta-analysis-toolkit 驱动。",
  "inputs": [
    {
      "name": "input",
      "flag": "--input",
      "label": "诊断研究 2×2 CSV",
      "format": "csv",
      "required": true,
      "primary": true,
      "mem_axis": "n_rows",
      "example": "example_data/diagnostic.csv",
      "spec": "2×2 诊断表:每行一个研究,需列 TP,FN,FP,TN(真阳/假阴/假阳/真阴)+ 研究名列(默认 study,用于森林图标注)。"
    }
  ],
  "params_schema": {
    "type": "object",
    "properties": {
      "study": {
        "type": "string",
        "title": "研究名列名",
        "default": "study"
      },
      "add_correction": {
        "type": "number",
        "title": "连续性校正(零格加数)",
        "default": 0.5
      }
    }
  },
  "param_flags": {
    "study": "--study",
    "add_correction": "--add_correction"
  },
  "outputs": [
    {
      "glob": "*.png",
      "display": "image"
    },
    {
      "glob": "*.csv",
      "display": "table"
    }
  ],
  "mem_hint": {
    "model": "linear",
    "killer_dim": "研究数",
    "matrix_copies": 3,
    "calibrated": true,
    "note": "meta 汇总数据内存极小, 恒绿"
  },
  "group": "diagnostics",
  "item_order": 30,
  "analysis": "lr_dor"
}