{
  "id": "meta_proportion_glmm",
  "title": "单臂比例 · 随机截距 GLMM",
  "title_en": "Proportion — random-intercept GLMM",
  "category": "meta",
  "family": "核心合并 Core Synthesis",
  "language": "R",
  "library": "launcher",
  "interp": "Rscript",
  "status": "turnkey",
  "tier": "T1",
  "entry": "adapters/meta/run_proportion.R",
  "workdir": "adapters/meta",
  "description": "单臂比例 meta 分析,二项-正态随机截距 logistic GLMM(Stijnen 2010):用精确二项似然直接建模事件数,避免连续性校正与两步 logit 的方差不稳,稀疏事件/小样本时优于倒方差法(Cochrane Handbook 10.6)。tau² 由极大似然估计。输出比例森林图 + 合并汇总表(合并比例 + 95%CI + 预测区间 + 异质性,反变换回自然尺度)。基于 meta 包 metaprop(method=\"GLMM\")。",
  "inputs": [
    {
      "name": "input",
      "flag": "--input",
      "label": "研究数据 CSV",
      "format": "csv",
      "required": true,
      "primary": true,
      "mem_axis": "n_rows",
      "example": "example_data/proportion.csv",
      "spec": "单臂比例:每行一个研究,需列 xi(事件/阳性数)、ni(该组样本量)、study(研究名列)。事件数不得超过样本量。列名可通过 --event/--n/--studlab 覆盖。"
    }
  ],
  "params_schema": {
    "type": "object",
    "properties": {
      "event": {
        "type": "string",
        "title": "事件数列名",
        "default": "xi"
      },
      "n": {
        "type": "string",
        "title": "样本量列名",
        "default": "ni"
      },
      "studlab": {
        "type": "string",
        "title": "研究名列名",
        "default": "study"
      }
    }
  },
  "param_flags": {
    "event": "--event",
    "n": "--n",
    "studlab": "--studlab"
  },
  "outputs": [
    {
      "glob": "*.png",
      "display": "image"
    },
    {
      "glob": "*.csv",
      "display": "table"
    }
  ],
  "mem_hint": {
    "model": "linear",
    "killer_dim": "研究数",
    "matrix_copies": 3,
    "calibrated": true,
    "note": "meta 汇总数据内存极小, 恒绿"
  },
  "group": "synthesis",
  "item_order": 100,
  "analysis": "glmm"
}