{
  "id": "meta_nma_cinema",
  "title": "证据确信度(贡献矩阵)",
  "title_en": "CINeMA confidence (contribution)",
  "category": "meta",
  "family": "网络 Meta 分析 NMA",
  "language": "R",
  "library": "launcher",
  "interp": "Rscript",
  "status": "turnkey",
  "tier": "T1",
  "entry": "adapters/meta/run_network.R",
  "workdir": "adapters/meta",
  "description": "证据贡献矩阵(netmeta::netcontrib,Papakonstantinou 2018):量化每个直接比较对各网络估计的贡献占比,是 CINeMA 证据确信度框架中『贡献 / 间接性』维度的定量基础(局部近似;完整 CINeMA 还评估研究内偏倚、不精确、异质性与不一致性)。输出贡献热图与贡献矩阵 CSV。",
  "inputs": [
    {
      "name": "input",
      "flag": "--input",
      "label": "网络数据 CSV",
      "format": "csv",
      "required": true,
      "primary": true,
      "mem_axis": "n_rows",
      "example": "example_data/network.csv",
      "spec": "对比格式(默认 format=contrast):每行一个研究内比较,需列 studlab(研究名)、treat1、treat2(两治疗)、TE(效应量)、seTE(标准误)。臂格式(format=arm):每行一个治疗臂,需 studlab、treat + 二分类 event,n 或连续型 n,mean,sd。"
    }
  ],
  "params_schema": {
    "type": "object",
    "properties": {
      "format": {
        "type": "string",
        "title": "数据格式",
        "default": "contrast",
        "enum": [
          "contrast",
          "arm"
        ]
      },
      "sm": {
        "type": "string",
        "title": "效应量",
        "default": "MD",
        "enum": [
          "MD",
          "SMD",
          "OR",
          "RR",
          "HR"
        ]
      },
      "reference": {
        "type": "string",
        "title": "参照治疗",
        "default": "plac"
      }
    }
  },
  "param_flags": {
    "format": "--format",
    "sm": "--sm",
    "reference": "--reference"
  },
  "outputs": [
    {
      "glob": "*.png",
      "display": "image"
    },
    {
      "glob": "*.csv",
      "display": "table"
    }
  ],
  "mem_hint": {
    "model": "linear",
    "killer_dim": "研究数",
    "matrix_copies": 3,
    "calibrated": true,
    "note": "meta 汇总数据内存极小, 恒绿"
  },
  "group": "nma",
  "item_order": 100,
  "analysis": "cinema"
}