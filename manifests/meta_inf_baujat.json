{
  "id": "meta_inf_baujat",
  "title": "Baujat 图(异质性贡献 vs 影响)",
  "title_en": "Baujat plot",
  "category": "meta",
  "family": "Meta 分析",
  "language": "R",
  "library": "launcher",
  "interp": "Rscript",
  "status": "turnkey",
  "tier": "T1",
  "entry": "adapters/meta/run_influence.R",
  "workdir": "adapters/meta",
  "description": "Baujat 图:以散点同时展示每个研究对总异质性 Q 的贡献(x 轴)与对合并估计的影响(y 轴),右上角研究即既制造异质性又左右结论的可疑离群点(Baujat et al. 2002, Stat Med)。附输出各研究的 (x,y) 坐标表。基于 metafor::baujat,由 meta-analysis-toolkit 驱动。",
  "inputs": [
    {
      "name": "input",
      "flag": "--input",
      "label": "研究数据 CSV",
      "format": "csv",
      "required": true,
      "primary": true,
      "mem_axis": "n_rows",
      "example": "example_data/influence.csv",
      "spec": "二分类 2×2:每行一个研究,需列 ai,bi,ci,di(处理组事件/非事件、对照组事件/非事件)+ 研究名列(默认 study)。连续型改选 SMD/MD 并提供 m1i,sd1i,n1i,m2i,sd2i,n2i;相关型 ZCOR 提供 ri,ni。"
    }
  ],
  "params_schema": {
    "type": "object",
    "properties": {
      "measure": {
        "type": "string",
        "title": "效应量",
        "default": "OR",
        "enum": [
          "OR",
          "RR",
          "RD",
          "PETO",
          "SMD",
          "MD",
          "ROM",
          "ZCOR"
        ]
      },
      "method": {
        "type": "string",
        "title": "τ² 估计方法",
        "default": "REML",
        "enum": [
          "REML",
          "DL",
          "PM",
          "SJ",
          "EB",
          "ML",
          "HE"
        ]
      },
      "knha": {
        "type": "boolean",
        "title": "Knapp-Hartung 校正(推荐)",
        "default": true
      },
      "slab": {
        "type": "string",
        "title": "研究名列名",
        "default": "study"
      }
    }
  },
  "param_flags": {
    "measure": "--measure",
    "method": "--method",
    "knha": "--knha",
    "slab": "--slab"
  },
  "analysis": "baujat",
  "outputs": [
    {
      "glob": "*.png",
      "display": "image"
    },
    {
      "glob": "*.csv",
      "display": "table"
    }
  ],
  "mem_hint": {
    "model": "linear",
    "killer_dim": "研究数",
    "matrix_copies": 3,
    "calibrated": true,
    "note": "meta 汇总数据内存极小, 恒绿"
  },
  "group": "robustness",
  "item_order": 20,
  "shape": "binary2x2"
}