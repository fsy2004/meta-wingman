{
  "id": "meta_bayesian",
  "title": "贝叶斯随机效应森林图",
  "title_en": "Bayesian RE forest",
  "category": "meta",
  "family": "贝叶斯 Bayesian",
  "language": "R",
  "library": "launcher",
  "interp": "Rscript",
  "status": "turnkey",
  "tier": "T1",
  "entry": "adapters/meta/run_bayesian.R",
  "workdir": "adapters/meta",
  "description": "贝叶斯 normal-normal 层次模型的随机效应 meta 分析森林图(bayesmeta,Röver 2020)。每个研究显示后验收缩估计,底部给出合并效应 mu 的 95% 可信区间与 95% 预测区间。默认弱信息半正态 tau 先验(scale=0.5,对数尺度效应量推荐值)。同时输出后验汇总表(mu/tau 后验中位数与 95% 可信区间、预测区间)。由 meta-analysis-toolkit 驱动。",
  "inputs": [
    {
      "name": "input",
      "flag": "--input",
      "label": "研究效应量 CSV",
      "format": "csv",
      "required": true,
      "primary": true,
      "mem_axis": "n_rows",
      "example": "example_data/bayesian.csv",
      "spec": "每行一个研究:需列 yi(该研究效应量,如 log-OR/log-RR/SMD)与 sei(其标准误)+ 研究名列(默认 study)。若手头是 2×2 计数,可先用 metafor::escalc('OR', ai,bi,ci,di) 取 yi 与 sqrt(vi)=sei。"
    }
  ],
  "params_schema": {
    "type": "object",
    "properties": {
      "tau_prior": {
        "type": "string",
        "title": "异质性 tau 先验分布",
        "default": "halfnormal",
        "enum": [
          "halfnormal",
          "halfcauchy",
          "uniform"
        ]
      },
      "tau_scale": {
        "type": "number",
        "title": "tau 先验 scale(半正态/半柯西尺度)",
        "default": 0.5
      },
      "slab": {
        "type": "string",
        "title": "研究名列名",
        "default": "study"
      }
    }
  },
  "param_flags": {
    "tau_prior": "--tau_prior",
    "tau_scale": "--tau_scale",
    "slab": "--slab"
  },
  "outputs": [
    {
      "glob": "*.png",
      "display": "image"
    },
    {
      "glob": "*.csv",
      "display": "table"
    }
  ],
  "mem_hint": {
    "model": "linear",
    "killer_dim": "研究数",
    "matrix_copies": 3,
    "calibrated": true,
    "note": "meta 汇总数据内存极小, 恒绿"
  },
  "group": "synthesis",
  "item_order": 130,
  "analysis": "forest"
}