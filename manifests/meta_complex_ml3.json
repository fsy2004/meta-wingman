{
  "id": "meta_complex_ml3",
  "title": "三层元分析(嵌套随机效应)",
  "title_en": "Three-level meta-analysis",
  "category": "meta",
  "family": "复杂数据结构 Complex Data Structures",
  "language": "R",
  "library": "launcher",
  "interp": "Rscript",
  "status": "turnkey",
  "tier": "T1",
  "entry": "adapters/meta/run_complex.R",
  "workdir": "adapters/meta",
  "description": "三层随机效应元分析(metafor::rma.mv, random = ~1|cluster/study):当同一 cluster(实验室/队列/地区)内含多个相关效应量时,把异质性拆成组间(第3层)与组内(第2层)两部分,并给出多层 I² 分解。输出按 cluster 分组的森林图与合并汇总表(含 σ²、I²、Q)。",
  "inputs": [
    {
      "name": "input",
      "flag": "--input",
      "label": "聚类效应量 CSV",
      "format": "csv",
      "required": true,
      "primary": true,
      "mem_axis": "n_rows",
      "example": "example_data/complex_clustered.csv",
      "spec": "每行一个效应量,需列 yi(效应量)、vi(其方差)、cluster(所属簇/研究群 id)、study(簇内子单位/结局名)。同一 cluster 的多行视为相关。"
    }
  ],
  "params_schema": {
    "type": "object",
    "properties": {
      "method": {
        "type": "string",
        "title": "方差成分估计方法",
        "default": "REML",
        "enum": [
          "REML",
          "ML"
        ]
      },
      "yi": {
        "type": "string",
        "title": "效应量列名",
        "default": "yi"
      },
      "vi": {
        "type": "string",
        "title": "方差列名",
        "default": "vi"
      },
      "cluster": {
        "type": "string",
        "title": "簇 id 列名",
        "default": "cluster"
      },
      "study": {
        "type": "string",
        "title": "簇内子单位列名",
        "default": "study"
      }
    }
  },
  "param_flags": {
    "method": "--method",
    "yi": "--yi",
    "vi": "--vi",
    "cluster": "--cluster",
    "study": "--study"
  },
  "outputs": [
    {
      "glob": "*.png",
      "display": "image"
    },
    {
      "glob": "*.csv",
      "display": "table"
    }
  ],
  "mem_hint": {
    "model": "linear",
    "killer_dim": "研究数",
    "matrix_copies": 3,
    "calibrated": true,
    "note": "Meta 分析为研究级汇总数据(通常几十行),内存开销极小,基本恒为绿灯。"
  },
  "group": "complex",
  "item_order": 10,
  "analysis": "ml3"
}