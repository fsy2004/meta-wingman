{
  "category": "meta",
  "family": "数据准备",
  "language": "R",
  "library": "launcher",
  "interp": "Rscript",
  "status": "turnkey",
  "tier": "T2",
  "entry": "adapters/meta/run_convert.R",
  "workdir": "adapters/meta",
  "outputs": [
    {
      "glob": "*.csv",
      "display": "table"
    }
  ],
  "mem_hint": {
    "model": "linear",
    "killer_dim": "研究数",
    "matrix_copies": 2,
    "calibrated": true
  },
  "group": "data",
  "id": "meta_conv_means",
  "title": "换算:两组均值±SD → SMD/MD",
  "title_en": "Convert: means±SD → SMD/MD",
  "description": "换算:两组均值±SD → SMD/MD。把原始数据换算成标准 yi(效应量)/ sei(标准误),输出的 converted.csv 可直接喂「通用倒方差森林」等分析。",
  "inputs": [
    {
      "name": "input",
      "flag": "--input",
      "label": "原始数据 CSV",
      "format": "csv",
      "required": true,
      "primary": true,
      "mem_axis": "n_rows",
      "example": "example_data/convert_means.csv",
      "spec": "连续型两组:m1i,sd1i,n1i,m2i,sd2i,n2i。输出 yi/sei。"
    }
  ],
  "params_schema": {
    "type": "object",
    "properties": {
      "measure": {
        "type": "string",
        "title": "效应量",
        "default": "SMD",
        "enum": [
          "SMD",
          "MD",
          "SMDH",
          "ROM"
        ]
      }
    }
  },
  "param_flags": {
    "measure": "--measure"
  },
  "item_order": 30,
  "shape": "continuous",
  "analysis": "es_means"
}