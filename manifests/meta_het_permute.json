{
  "id": "meta_het_permute",
  "title": "置换检验元回归",
  "title_en": "Permutation test for meta-regression",
  "category": "meta",
  "family": "异质性与调节 Heterogeneity & Moderators",
  "language": "R",
  "library": "launcher",
  "interp": "Rscript",
  "status": "turnkey",
  "tier": "T2",
  "entry": "adapters/meta/run_heterogeneity.R",
  "workdir": "adapters/meta",
  "description": "对连续调节变量的元回归做置换检验:重排效应量若干次得到系数与 Omnibus Q_M 的置换 p 值,在研究数较少时比常规参考分布更稳健(Higgins & Thompson 2004)。基于 metafor::permutest。",
  "analysis": "permute",
  "inputs": [
    {
      "name": "input",
      "flag": "--input",
      "label": "研究数据 CSV",
      "format": "csv",
      "required": true,
      "primary": true,
      "mem_axis": "n_rows",
      "example": "example_data/heterogeneity.csv",
      "spec": "二分类 2×2:每行一个研究,需列 ai,bi,ci,di + 研究名列(默认 study)+ 一个数值调节列(默认 ablat,用于元回归)。"
    }
  ],
  "params_schema": {
    "type": "object",
    "properties": {
      "measure": {
        "type": "string",
        "title": "效应量",
        "default": "OR",
        "enum": [
          "OR",
          "RR",
          "RD",
          "PETO"
        ]
      },
      "moderator": {
        "type": "string",
        "title": "元回归列名(连续调节变量)",
        "default": "ablat"
      },
      "iter": {
        "type": "integer",
        "title": "置换次数",
        "default": 1000,
        "minimum": 99
      },
      "method": {
        "type": "string",
        "title": "τ² 估计方法",
        "default": "REML",
        "enum": [
          "REML",
          "DL",
          "PM",
          "SJ",
          "EB",
          "ML",
          "HE"
        ]
      },
      "knha": {
        "type": "boolean",
        "title": "Knapp-Hartung 校正(推荐)",
        "default": true
      },
      "slab": {
        "type": "string",
        "title": "研究名列名",
        "default": "study"
      }
    }
  },
  "param_flags": {
    "measure": "--measure",
    "moderator": "--moderator",
    "iter": "--iter",
    "method": "--method",
    "knha": "--knha",
    "slab": "--slab"
  },
  "outputs": [
    {
      "glob": "*.png",
      "display": "image"
    },
    {
      "glob": "*.csv",
      "display": "table"
    }
  ],
  "mem_hint": {
    "model": "linear",
    "killer_dim": "研究数",
    "matrix_copies": 3,
    "calibrated": true,
    "note": "meta 汇总数据内存极小, 恒绿"
  },
  "group": "heterogeneity",
  "item_order": 50,
  "shape": "binary2x2"
}